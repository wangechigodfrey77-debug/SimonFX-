rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper validation for string IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper validation for UserSettings
    function isValidUserSettings(data) {
      return data.userName is string
          && data.baseCurrency is string
          && data.startingBalance is number;
    }

    // Helper validation for Trade
    function isValidTrade(data) {
      return data.id is string
          && data.pair is string
          && data.entryPrice is number
          && data.lotSize is number
          && data.status is string;
    }

    // Whitelist rules helpers
    function isWhitelisted(email) {
      return email.lower() == 'wangechigodfrey77@gmail.com'
        || exists(/databases/$(database)/documents/whitelist/$(email.lower()));
    }

    function getWhitelistData(email) {
      return get(/databases/$(database)/documents/whitelist/$(email.lower())).data;
    }

    function isBootstrapAdmin() {
      return isSignedIn() 
        && 'email' in request.auth.token 
        && (
          request.auth.token.email.lower() == 'wangechigodfrey77@gmail.com'
          || request.auth.token.email.matches('(?i)^wangechigodfrey77@gmail\\.com$')
        );
    }

    function isWhitelistedAndAdmin() {
      return isBootstrapAdmin() || (
        isSignedIn() 
        && 'email' in request.auth.token 
        && isWhitelisted(request.auth.token.email)
        && 'role' in getWhitelistData(request.auth.token.email)
        && getWhitelistData(request.auth.token.email).role == 'admin'
      );
    }

    function isWhitelistedAndViewer() {
      return !isBootstrapAdmin() && (
        isSignedIn() 
        && 'email' in request.auth.token 
        && isWhitelisted(request.auth.token.email)
        && 'role' in getWhitelistData(request.auth.token.email)
        && getWhitelistData(request.auth.token.email).role == 'viewer'
      );
    }

    function isWhitelistedUser() {
      return isBootstrapAdmin() || (
        isSignedIn() 
        && 'email' in request.auth.token 
        && isWhitelisted(request.auth.token.email)
      );
    }

    // Whitelist collection rules
    match /whitelist/{email} {
      // Allow bootstrap admin to initialize their own whitelist profile
      allow create, update: if isSignedIn()
        && 'email' in request.auth.token
        && request.auth.token.email.lower() == 'wangechigodfrey77@gmail.com'
        && email.lower() == 'wangechigodfrey77@gmail.com';

      // Whitelisted admins can read, create, update, delete all whitelist entries
      allow read, write: if isBootstrapAdmin() || isWhitelistedAndAdmin();
      // Any authenticated user can fetch their own or active whitelist record
      allow get: if isSignedIn();
    }

    // User Profile
    match /users/{userId} {
      allow get: if (isOwner(userId) || userId == 'shared') && (isBootstrapAdmin() || isWhitelistedUser());
      allow create: if (isOwner(userId) || userId == 'shared') 
        && (
          isBootstrapAdmin()
          ||
          (isWhitelistedAndAdmin() && isValidUserSettings(request.resource.data))
        );
      allow update: if (isOwner(userId) || userId == 'shared') 
        && (
          isBootstrapAdmin()
          ||
          (isWhitelistedAndAdmin() && isValidUserSettings(request.resource.data))
        );
      allow delete: if (isOwner(userId) || userId == 'shared') && (isBootstrapAdmin() || isWhitelistedAndAdmin());

      // Subcollection: Trades
      match /trades/{tradeId} {
        allow get, list: if (isOwner(userId) || userId == 'shared') && (isBootstrapAdmin() || isWhitelistedUser());
        
        allow create: if (isOwner(userId) || userId == 'shared') 
          && (
            (isBootstrapAdmin() && isValidId(tradeId))
            ||
            (isWhitelistedAndAdmin() && isValidId(tradeId) && isValidTrade(request.resource.data))
          );

        allow update: if (isOwner(userId) || userId == 'shared')
          && (
            isBootstrapAdmin()
            ||
            (isWhitelistedAndAdmin() && isValidTrade(request.resource.data))
          );

        allow delete: if (isOwner(userId) || userId == 'shared') && (isBootstrapAdmin() || isWhitelistedAndAdmin());
      }
    }
  }
}
